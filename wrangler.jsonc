{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tsenasoamanampy",
  "compatibility_date": "2026-06-22",
  "main": "./src/index.js",
  "assets": {
    "directory": "./public",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "operations-db",
      "database_id": "0aeb7684-730c-4ea3-a03c-6799828c36d3"
    }
  ]
}
